# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Python
__pycache__/
.pytest_cache/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
dist/
build/

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code local settings (agents and commands ARE tracked)
.claude/settings.local.json

# Engagement data (client-confidential — never commit)
/engagements/
/Engagement/

# Team Ops (manager second brain) — content is local-only
# Only structure, READMEs, and templates are tracked
team-ops/inbox/*
team-ops/people/*
team-ops/engagements/*
team-ops/areas/*
team-ops/meetings/*
team-ops/decisions/*
team-ops/actions/*
team-ops/archive/*
!team-ops/**/README.md
!team-ops/templates/**

# Environment files (may contain secrets)
.env
.env.local
.env.*.local
.git_askpass.sh

# PII anonymization artifacts (contain real client names)
.pii_mapping.json
.anon_*

# Temporary files
*.tmp
/tmp/
interim_*.md

# OS-generated
Thumbs.db
Desktop.ini

# Miscellaneous
*.webloc
